{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "/api/search.py" },
    { "src": "/api/holdings", "dest": "/api/holdings.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
